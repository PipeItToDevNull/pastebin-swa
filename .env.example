# Display name shown in the page title and UI
VITE_SITE_NAME=KittyPost

# URL linked in the footer "on GitHub" anchor (leave blank to link to #)
VITE_REPO_URL=

# How many hours a paste is kept before automatic deletion (used by both server and frontend)
VITE_PASTE_MAX_AGE_HOURS=24

# How often (in hours) the server scans for and deletes expired pastes
CLEANUP_INTERVAL_HOURS=1

# Port the Express server listens on
PORT=3000

# Directory where paste files are stored; relative paths are resolved from the repo root
STORAGE_DIR=data

# Maximum accepted request body size (Express/bytes format: 1mb, 512kb, etc.)
MAX_BODY_SIZE=1mb